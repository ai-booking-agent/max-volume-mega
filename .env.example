# The Max Volume Mega playlist (used only to tell the local Spotify app what to play)
SPOTIFY_PLAYLIST_ID=1uu3OwGgJO4gfxZzGsXwDf

# The Discord channel to open once the screenshot is ready. The screenshot is
# copied to your clipboard and this channel is opened — you paste (Cmd+V) and
# send it yourself. Nothing is posted automatically (see src/discord_notify.py
# for why: automating a personal Discord account to send messages violates
# Discord's Terms of Service).
DISCORD_CHANNEL_URL=https://discord.com/channels/1173706955852873818/1206527185964236830

# Stats for Spotify page to screenshot
STATS_URL=https://www.statsforspotify.com/track/recent

# Polling behavior while waiting for the recent-tracks page to fill with today's plays
POLL_INTERVAL_SECONDS=300
MAX_POLL_HOURS=8
